{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clicky",
  "version": "0.1.0",
  "identifier": "app.clicky.tutor",
  "build": {
    "beforeDevCommand": "vite --config frontend/vite.config.ts",
    "beforeBuildCommand": "vite build --config frontend/vite.config.ts",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "command",
        "title": "Clicky Command",
        "url": "/command",
        "width": 760,
        "height": 580,
        "minWidth": 560,
        "minHeight": 120,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false
      },
      {
        "label": "overlay",
        "title": "Clicky Overlay",
        "url": "/overlay",
        "fullscreen": true,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "../python",
      "../requirements.txt"
    ]
  }
}
